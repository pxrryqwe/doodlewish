# ----- Database (Neon Postgres) -----
# Create a project at https://console.neon.tech/ and copy the connection
# string into DATABASE_URL. Drizzle uses the HTTP (serverless) driver.
DATABASE_URL=postgres://USER:PASSWORD@HOST/dbname?sslmode=require

# ----- Object storage (Cloudflare R2) -----
# Create an R2 bucket + API token at https://dash.cloudflare.com/?to=/:account/r2.
# The bucket must allow public reads (or be fronted by a Worker / custom domain).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=doodlewish
R2_PUBLIC_BASE_URL=https://<your-r2-bucket>.r2.dev

# ----- App base URL -----
# Used for absolute URLs in metadata and OG. Optional in dev.
# NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ----- Analytics (optional) -----
# Set NEXT_PUBLIC_GA_ID to enable GA4 tracking. Omit to disable analytics.
# NEXT_PUBLIC_GA_ID=G-XXXXXXXX

# ----- Admin dashboard -----
# Single shared password gates /admin. Cookie is HMAC-signed with the secret.
ADMIN_PASSWORD=changeme
ADMIN_SESSION_SECRET=use-a-long-random-string-at-least-32-chars

# ----- GA Data API (for /admin metrics) -----
# Create a service account in Google Cloud, grant it Viewer on the GA4
# property, then paste its email + private key (with literal \n) here.
# GA_PROPERTY_ID=000000000
# GA_SERVICE_ACCOUNT_EMAIL=name@project.iam.gserviceaccount.com
# GA_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ----- Cron -----
# Header value required to invoke /api/cron/cleanup. Configure as a custom
# header in Vercel Cron → x-cron-secret.
CRON_SECRET=use-a-long-random-string
